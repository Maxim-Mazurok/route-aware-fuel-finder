{
  "name": "route-aware-fuel-finder",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c auto \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite --host 127.0.0.1 --port 4173",
    "dev:api": "tsx watch server/index.ts",
    "build": "npm run build:web && npm run build:api",
    "build:web": "tsc -b && vite build",
    "build:api": "tsc -p tsconfig.server.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "start:api": "node server-dist/index.js",
    "osm:download": "sh ./scripts/download-osm-extract.sh",
    "osm:up": "docker compose up -d osrm-routed",
    "osm:up:full": "docker compose --profile local-geocode up -d osrm-routed nominatim",
    "osm:down": "docker compose down",
    "osm:logs": "docker compose logs -f osrm-routed",
    "osm:logs:full": "docker compose --profile local-geocode logs -f osrm-routed nominatim"
  },
  "dependencies": {
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@mantine/core": "^8.3.16",
    "@mantine/hooks": "^8.3.16",
    "@tabler/icons-react": "^3.40.0",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "leaflet": "^1.9.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
