{
  "extends": "./tsconfig.node.json",
  "compilerOptions": {
    "composite": false,
    "outDir": "./server-dist",
    "rootDir": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2023"],
    "types": ["node"],
    "erasableSyntaxOnly": false
  },
  "include": ["server/**/*.ts", "src/domain/**/*.ts"]
}
